{
  "name": "@signalfoundry/ui",
  "version": "0.1.0",
  "description": "SignalFoundry design system — presentational primitives and design tokens.",
  "license": "UNLICENSED",
  "type": "module",
  "sideEffects": ["**/*.css"],
  "main": "./dist/index.es.js",
  "module": "./dist/index.es.js",
  "types": "./dist/index.d.ts",
  "style": "./dist/styles.css",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.es.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": ["dist"],
  "scripts": {
    "clean": "rm -rf dist",
    "build:js": "tsup",
    "build:css": "tailwindcss -i ./styles.css -o ./dist/styles.css",
    "build": "npm run build:js && npm run build:css"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "tailwindcss": "^4.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0"
  }
}
